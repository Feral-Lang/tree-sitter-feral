{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "feral",
      "camelcase": "Feral",
      "title": "Feral",
      "scope": "source.feral",
      "path": ".",
      "file-types": [
        "fecl",
        "fer"
      ],
      "injection-regex": "feral",
      "class-name": "TreeSitterFeral"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree sitter parser for Feral",
    "authors": [
      {
        "name": "Elec"
      }
    ],
    "links": {
      "repository": "https://github.com/Feral-Lang/TreeSitter"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}